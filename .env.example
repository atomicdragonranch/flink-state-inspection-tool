# AWS credentials (picked up by DefaultCredentialsProvider)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Custom S3 endpoint for LocalStack or MinIO
# AWS_ENDPOINT_URL=http://localhost:4566

# S3 auto-detection: comma-separated list of S3 paths to scan on startup
# FLINK_S3_CHECKPOINT_PATHS=s3://my-bucket/flink/checkpoints,s3://other-bucket/checkpoints
